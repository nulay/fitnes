<?xml version="1.0" encoding="UTF-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background">

    <!-- Header с иконкой -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_fitness"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЛФК ТРЕНАЖЁР"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="для позвоночника"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/button_circle"
            android:src="@android:drawable/ic_menu_preferences"
            android:scaleType="center"
            android:contentDescription="Настройки"/>
    </LinearLayout>

    <!-- Основной контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

<TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выберите урок"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"/>

        <!-- Кнопка создать новый -->
        <Button
            android:id="@+id/btnNew"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="+ НОВЫЙ КОМПЛЕКС"
            android:textSize="13sp"
            android:textColor="@color/accent"
            android:background="@drawable/card_background"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="8dp"/>

        <ListView
            android:id="@+id/lvLessons"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/list_background"
            android:dividerHeight="1dp"
            android:layout_marginBottom="16dp"/>

        <!-- Карточка упражнения -->
        <LinearLayout
            android:id="@+id/cardExercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvExercise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Нажмите СТАРТ"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Кнопки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="СТАРТ"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_primary"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="СТОП"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_secondary"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Голос -->
        <Button
            android:id="@+id/btnVoice"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="🎤 ГОЛОС"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:background="@drawable/button_voice"
            android:layout_marginBottom="8dp"/>

        <!-- Изменить / Удалить (долгое нажатие на уроке) -->
    </LinearLayout>

</LinearLayout>