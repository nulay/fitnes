<?xml version="1.0" encoding="UTF-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/white">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ГОЛОСОВОЕ СОЗДАНИЕ"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvVoiceStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Нажмите микрофон и назовите упражнение"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"/>

        <Button
            android:id="@+id/btnVoiceInput"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🎤 ГОЛОСОВОЙ ВВОД"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_voice"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ИЛИ ВВЕДИТЕ ВРУЧНУЮ:"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etExerciseTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Название (например: Давление на лоб)"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etExerciseInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Инструкция"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etHoldTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Секунд"
                android:inputType="number"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etRepeats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Повторений"
                android:inputType="number"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnCancelExercise"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="ОТМЕНА"
                android:textColor="#666666"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSaveExercise"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="СОХРАНИТЬ"
                android:textColor="#1A237E"
                android:background="@drawable/button_primary"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>