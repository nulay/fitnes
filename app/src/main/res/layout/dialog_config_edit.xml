<?xml version="1.0" encoding="UTF-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/background_dark">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="КОНФИГУРАЦИЯ API"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Название"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etConfigName"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:hint="Название"
        android:inputType="text"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/card_background"
        android:paddingStart="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Модель"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerModel"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/card_background"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Свой URL (опционально)"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etCustomUrl"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:hint="https://api.custom.com/v1"
        android:inputType="textUri"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/card_background"
        android:paddingStart="12dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="API Key"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etConfigApiKey"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:hint="Введите API ключ"
        android:inputType="textPassword"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/card_background"
        android:paddingStart="12dp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelConfig"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="ОТМЕНА"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/card_background"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSaveConfig"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="СОХРАНИТЬ"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:background="@drawable/button_primary"/>
    </LinearLayout>

</LinearLayout>